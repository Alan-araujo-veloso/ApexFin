{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
   "esModuleInterop": true,
   "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}